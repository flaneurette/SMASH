>>>>>>> d3dbde7895df9e70d076798e821e9e180b22b0ee

// Save firewall
let iptables = $(iptables-save > migration/firewall/iptables.txt);
let ipset = $(ipset save > migration/firewall/ipset.txt); 
echo `------------------------------------------------------------ done!`;

echo `Starting to backup database...`;
// Save database
let databases = $(mysqldump -u "$mysql_user" -p "$mysql_pass" --all-databases --single-transaction --routines --triggers > "migration/databases/databases.sql");
echo `------------------------------------------------------------ done!`;

// Compress folders
let files = [
    'var/www/',
    'etc/letsencrypt/',
    'etc/apache2/',
    'etc/crontab',
    'etc/cron.d/',
    'var/spool/cron/crontabs/',
    'etc/php/',
    'etc/unbound/',
    'etc/tailscale/',
    'etc/headscale/',
    'etc/postfix/',
    'etc/dovecot/',
    'var/mail/',
    'etc/ssh/'
];

files.forEach(f => {
    echo `Making backup of: $f`;
    tar -czvf "migration/compressed/$(basename "$f").tar.gz" "$f";
    echo `---------------------------------------------------------done!`;
});

